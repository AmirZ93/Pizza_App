@package.Import(Pizza.PackageEditor)

@Pizza.Function(move)[self,distance]:
self.draw("fd",distance)
;
@Pizza.Function(rotate)[self,angel]:
self.draw("rt",angel)
;
@Pizza.Function(PenUp)[self]:
self.draw("pu")
;
@Pizza.Function(PenDown)[self]:
self.draw("pd")
;
@Pizza.Function(PenColor)[self,colorpen]:
self.draw("color",colorpen)
;
@Pizza.Function(Done)[self]:
self.terminal("Done")
self.draw("done")
;